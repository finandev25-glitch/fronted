{
  "manifest_version": 3,
  "name": "Voucher Side Panel",
  "version": "1.0.0",
  "key": "",
  "description": "Panel lateral persistente para ver el voucher y los datos clave del depósito.",
  "permissions": ["sidePanel", "storage", "tabs", "scripting", "activeTab", "windows"],
  "host_permissions": [
    "http://localhost:*/*",
    "http://127.0.0.1:*/*",
    "https://*.gnfcio.easypanel.host/*",
    "https://www.bbvanetcash.pe/*",
    "https://*.bbvanetcash.pe/*",
    "https://www.tlcbcp.com/*",
    "https://tlcbcp.com/*",
    "https://*.tlcbcp.com/*",
    "https://empresas.interbank.pe/*",
    "https://*.interbank.pe/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Abrir panel de vouchers"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:*/*",
        "http://127.0.0.1:*/*",
        "https://*.gnfcio.easypanel.host/*",
        "https://www.bbvanetcash.pe/*",
        "https://*.bbvanetcash.pe/*",
        "https://www.tlcbcp.com/*",
        "https://tlcbcp.com/*",
        "https://*.tlcbcp.com/*",
        "https://empresas.interbank.pe/*",
        "https://*.interbank.pe/*"
      ],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
