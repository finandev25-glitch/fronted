# Frontend (Vite)
VITE_USE_MOCK_DATA=false

# API externa para rutas /api y SSE
# También usada por vite.config.ts como target del proxy de desarrollo/preview
# (ya no hay ninguna IP hardcodeada en el código: este valor es la única fuente).
VITE_API_BASE_URL=https://n5vqr8.tyresperu.com

# URL del hub de SignalR. Si se omite, signalrService.js usa "/hubs/deposits"
# (ruta relativa, funciona detrás del proxy de Vite o si el front y el backend
# comparten el mismo dominio). Defínela explícitamente en despliegues donde el
# frontend y el backend estén en dominios distintos.
# IMPORTANTE: debe ser https:// (NO wss://) — el cliente de SignalR hace una
# negociación HTTP normal antes de subir a WebSocket; si se le pasa wss://
# directamente, el fetch() interno falla con "URL scheme wss is not supported".
VITE_SIGNALR_HUB_URL=https://n5vqr8.tyresperu.com/hubs/deposits

VITE_GOOGLE_API_KEY=tu_google_api_key
VITE_GOOGLE_CLIENT_ID=tu_google_client_id
